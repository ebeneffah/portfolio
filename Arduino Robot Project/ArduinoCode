#include <stdio.h>
#include <Servo.h>

// Define pins ---------------
#define HC_SR04_Tx 2
#define HC_SR04_Rx 3
#define ServoL_pin 13
#define ServoR_pin 12

// Define constants ----------
#define DEBUG true
#define wheelDiam 66.0
#define wheelRad (wheelDiam/2.0)
#define axleLen 104.0

// Define states
#define STATE_FORWARD 1
#define STATE_BACKWARD 2
#define STATE_TURN_LEFT 3

// Global variables ----------
Servo servoL;
Servo servoR; 
float driveL, driveR;
float dist;
int state;

void setup() {
  Serial.begin(9600);
  cprintf(">>> Initializing stuff ..................\n");
  pinMode(HC_SR04_Tx,OUTPUT);
  pinMode(HC_SR04_Rx,INPUT);
  servoL.attach(ServoL_pin);
  servoR.attach(ServoR_pin);
  // Stop any servo movement
  driveServos(0.0,0.0);  
  
  cprintf(">>> Pausing 2 secs ......................\n");
  delay(2000);
  cprintf(">>> Starting  ...........................\n");

  state = STATE_FORWARD;
  
}


void loop() {

  switch(state) {
    case STATE_FORWARD :

      // insert code to set driveL and driveR
      // and send to servos
      driveL=40;
      driveR=50;
      driveServos(driveL,driveR);

      
      // insert code to get the dist measurement
      
      int delayVal;
      // delay of 60 ms required by datasheet
      delayVal = 60;
      dist = getDistance();
      cprintf("dist = %f\n",dist);
      delay(delayVal);
      
      // test the dist and transit to next state
      if ( (dist < 150) && (dist != -1) ) {
        cprintf("Transit to state STATE_BACKWARD\n");
        state = STATE_BACKWARD;
      }
      break;

    case STATE_BACKWARD :

      // insert code to set driveL and driveR
      // and send to servos
      driveL=-50;
      driveR=-50;
      driveServos(driveL,driveR);

      // insert a delay for a number of millisecs
      delay(1000);
      cprintf("Transit to state STATE_TURN_LEFT\n"); 
      state = STATE_TURN_LEFT;
      break;
      
    case STATE_TURN_LEFT :
      // insert code to set driveL and driveR
      // and send to servos
      driveL=0;
      driveR=50;
      driveServos(driveL,driveR);

      // insert a delay for a number of millisecs
      delay(1200);
      cprintf("Transit to state STATE_FORWARD\n"); 
      state = STATE_FORWARD;
      break;         
  }

  
}

float getDistance() {
  long duration;
  float mm;
  digitalWrite(HC_SR04_Tx, LOW);
  delayMicroseconds(2);
  digitalWrite(HC_SR04_Tx, HIGH);
  delayMicroseconds(10);
  digitalWrite(HC_SR04_Tx, LOW);

  duration = pulseIn(HC_SR04_Rx, HIGH);
  mm = 10*duration / 29 / 2;

  // Catch 'bad' values and report as mm = -1;
  if(duration < 600) mm = -1;
  if(mm > 4000) mm = -1;  
  //if(DEBUG) cprintf("Dist (mm) = %f\n",mm);
  return mm;
  
}

void driveServos(float _driveL, float _driveR) {
  servoL.writeMicroseconds(1500 + (int)_driveL);
  servoR.writeMicroseconds(1500 - (int)_driveR);
}
